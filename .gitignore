# Byte-code files
*.pyc
__pycache__/
# Operating System files
.DS_Store # macOS
Thumbs.db # Windows
# Environments
.venv/
venv/
env/
ENV/
# Build artifacts and distributions
dist/
build/
*.egg-info/
# Documentation
/site/ # for mkdocs
# Testing and coverage
.coverage
.pytest_cache/
nosetests.xml
coverage.xml
# Editors and IDEs
.idea/ # PyCharm
.vscode/ # VS Code
*.swp # Vim
# Jupyter Notebook Checkpoints
.ipynb_checkpoints
# mypy static analysis cache
.mypy_cache/
# Pyre type checker
.pyre/
# virtualenv automatically generates a .gitignore file, but if it doesn't you should manually add the folder you used
subscriptions.json
config.json
node_modules/
.claude/
.vscode/

# Tauri / Rust build output
src-tauri/target/
# Compiled sidecar binaries (generated by scripts/build-sidecar.sh before tauri build)
src-tauri/binaries/
# PyInstaller artefacts
*.spec.log
# Generated icon source (regenerated by npm run generate-icons)
src-tauri/icons/icon-source.png
