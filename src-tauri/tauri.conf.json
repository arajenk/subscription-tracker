{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "subtracker",
  "version": "0.1.0",
  "identifier": "io.subtracker",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build -- --mode tauri"
  },
  "app": {
    "windows": [
      {
        "title": "subtracker",
        "width": 1280,
        "height": 840,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/subtracker-backend"],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
